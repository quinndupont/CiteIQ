{
  "name": "iqm-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute iqm-db --local --file=./src/db/schema.sql",
    "db:migrate:prod": "wrangler d1 execute iqm-db --remote --file=./src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240314.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.0.0"
  }
}
